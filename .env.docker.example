# AdByG0d Docker Compose environment example
# Copy to .env for Docker Compose.
# Never commit real .env files.

# Required by API. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Development compose runs DEBUG=true, but set a real value anyway.
SECRET_KEY=CHANGE_ME_DEVELOPMENT_ONLY

# Development compose database. Production compose overrides this with PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:////app/data/adbygod.db

# Production PostgreSQL settings. Change POSTGRES_PASSWORD before production use.
POSTGRES_DB=adbygod
POSTGRES_USER=adbygod
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION_DB_PASSWORD

# Production runtime hardening
ENVIRONMENT=production
DEBUG=false
AUTH_COOKIE_SECURE=true
ALLOWED_ORIGINS=https://adbygod.example.com
NEXT_PUBLIC_API_URL=https://api.adbygod.example.com

# Redis/Celery defaults are wired to compose service names by docker-compose files.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# AI provider keys. Leave blank unless used.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2
AI_DEFAULT_PROVIDER=claude

# Dangerous capabilities. Keep disabled unless explicitly authorized.
ENABLE_COMMAND_EXECUTION=false
COMMAND_EXECUTION_ALLOWLIST=
ENABLE_AI_ARBITRARY_SHELL=false
ENABLE_CHAIN_BUILDER=false
ENABLE_TUNNEL_MANAGEMENT=false

# Graph engine (Neo4j) — required, no fallback
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
