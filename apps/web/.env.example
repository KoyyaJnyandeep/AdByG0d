# AdByG0d web — copy to .env.local
# Do not put backend secrets or provider API keys in NEXT_PUBLIC_* variables.

# API base URL for browser-side requests
NEXT_PUBLIC_API_URL=http://localhost:8000

# API URL for SSR/prefetch (can differ from public URL in proxied deployments)
API_URL=http://localhost:8000

# WebSocket URL override — leave blank for local dev (falls back to NEXT_PUBLIC_API_URL with http→ws swap)
# Behind a reverse proxy, set to: wss://api.yourdomain.com
NEXT_PUBLIC_WS_URL=
