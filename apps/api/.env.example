# AdByG0d API environment example
# Copy to apps/api/.env for local development.
# Never commit real .env files.

# App
APP_NAME=AdByG0d Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
SQL_ECHO=false
AUTO_CREATE_TABLES=true

# Required security secret. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Database. SQLite is for local development only; use PostgreSQL in production.
DATABASE_URL=sqlite+aiosqlite:///./adbygod.db

# Redis and Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Per-job subprocess workspace. Keep outside the repository when possible.
JOB_WORKSPACE_BASE=/tmp/adbygod_jobs
JOB_WORKSPACE_RETAIN_ON_FAILURE=false

# Auth and cookies
ACCESS_TOKEN_EXPIRE_MINUTES=30
STREAM_TOKEN_EXPIRE_MINUTES=5
ALGORITHM=HS256
AUTH_COOKIE_NAME=adbygod_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
STRICT_COOKIE_ORIGIN_CHECK=true
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# CORS. Use explicit origins only; production rejects wildcard origins.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional dev bootstrap. Only activates when DEBUG=true.
ALLOW_DEV_BOOTSTRAP=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_FULL_NAME=

# Collection and evidence retention
MAX_SCAN_DURATION_HOURS=24
EVIDENCE_RETENTION_DAYS=365
ENABLE_PUBLIC_ASSESSMENT_SUMMARY=false

# AI provider configuration. Leave keys blank unless you use that provider.
AI_DEFAULT_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Dangerous capabilities. Disabled by default and require privileged authorization checks.
ENABLE_COMMAND_EXECUTION=false
COMMAND_EXECUTION_ALLOWLIST=
ENABLE_AI_ARBITRARY_SHELL=false
COMMAND_EXECUTION_TIMEOUT_SECONDS=60
ENABLE_CHAIN_BUILDER=false
ENABLE_TUNNEL_MANAGEMENT=false

# Tunnel/process management. Configure only when tunnel management is enabled.
TUNNEL_MANAGEMENT_BINARY_ALLOWLIST=chisel,ligolo-proxy
CHISEL_BINARY_PATH=
CHISEL_BINARY_SHA256=
LIGOLO_PROXY_BINARY_PATH=
LIGOLO_PROXY_BINARY_SHA256=
MANAGED_SSH_BINARY=ssh
MANAGED_TUNNEL_PORT_MIN=41000
MANAGED_TUNNEL_PORT_MAX=49000
MANAGED_TUNNEL_MAX_LIFETIME_MINUTES=240

# Optional AD command overlay. Use synthetic/test data only in public examples.
AD_COMMANDS_OVERLAY_PATH=
